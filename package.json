{
  "name": "cominsula",
  "version": "0.1.0",
  "private": true,
  "description": "Cominsula.io - Tenant Reliability & Property Management MVP (Convex backend + Vite/React SPA)",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:web",
    "dev:backend": "convex dev",
    "dev:web": "pnpm --filter @cominsula/web dev",
    "codegen": "convex codegen",
    "build:web": "pnpm --filter @cominsula/web build",
    "seed": "convex run seed:run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm --filter @cominsula/web typecheck",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "convex-test": "^0.0.37",
    "eslint": "^9.17.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@cominsula/shared": "workspace:*",
    "@convex-dev/auth": "^0.0.87",
    "@convex-dev/rate-limiter": "^0.2.8",
    "@auth/core": "^0.37.0",
    "convex": "^1.17.0",
    "convex-helpers": "^0.1.70",
    "lucia": "^3.2.2"
  },
  "packageManager": "pnpm@11.11.0"
}
